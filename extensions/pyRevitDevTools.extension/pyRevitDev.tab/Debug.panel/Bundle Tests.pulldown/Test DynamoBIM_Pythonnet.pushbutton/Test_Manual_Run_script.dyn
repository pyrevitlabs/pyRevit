  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('AdWindows')\r\nfrom System import AppDomain, Array, Object, Type\r\n\r\nadw = None\r\nfor a in AppDomain.CurrentDomain.GetAssemblies():\r\n    if 'AdWindows' in str(a.FullName):\r\n        adw = a\r\n        break\r\n\r\nRIType = adw.GetType('Autodesk.Internal.InfoCenter.ResultItem')\r\nCMType = adw.GetType('Autodesk.Windows.ComponentManager')\r\nempty = Array.CreateInstance(Object, 0)\r\n\r\ndef on_click(sender, e):\r\n    pass\r\n\r\ndef make_ri(clr_type):\r\n    for c in clr_type.GetConstructors():\r\n        if len(c.GetParameters()) == 0:\r\n            return c.Invoke(empty)\r\n\r\ndef balloon(hdr, txt, tip='', grp='', fav=False, new=False):\r\n    ri = make_ri(RIType)\r\n    ri.Category = hdr\r\n    ri.Title = txt\r\n    ri.TooltipText = tip\r\n    ri.Group = grp\r\n    ri.IsFavorite = fav\r\n    ri.IsNew = new\r\n    ri.ResultClicked += on_click\r\n    pp = CMType.GetProperty('InfoCenterPaletteManager')\r\n    pm = pp.GetValue(None)\r\n    pt = Array.CreateInstance(Type, 1)\r\n    pt[0] = RIType\r\n    m = pm.GetType().GetMethod('ShowBalloon', pt)\r\n    ar = Array.CreateInstance(Object, 1)\r\n    ar[0] = ri\r\n    return m.Invoke(pm, ar)\r\n\r\nh = 'header' if IN[0] is None else IN[0]\r\nt = 'Mission Accomplished' if IN[1] is None else IN[1]\r\nif IN[2]:\r\n    balloon(h, t, 'tooltip', 'group', True, True)",
