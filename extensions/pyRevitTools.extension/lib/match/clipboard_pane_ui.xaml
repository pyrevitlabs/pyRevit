<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White">
    <Page.Resources>
        <Style x:Key="ClearButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Funnel+Az: default substring/fuzzy search mode -->
        <Canvas x:Key="filterIcon" Width="16" Height="16">
            <Path Canvas.Top="-7" Canvas.Left="-5"
                  Data="F1 M 45.4403,56.9637L 45.4403,55.0463L 52.8201,44.5143L 52.8201,44.4237L 46.13,44.4237L 46.13,41.4774L 57.372,41.4774L 57.372,43.5352L 50.1532,53.9265L 50.1532,54.0174L 57.4869,54.0174L 57.4869,56.9637L 45.4403,56.9637 Z M 34.8333,61.75L 34.8333,42.75L 19,20.5833L 57,20.5833L 41.1667,42.75L 41.1667,58.5833L 34.8333,61.75 Z M 25.903,52.8055L 21.4072,52.8055L 20.289,56.9855L 16.6085,56.9855L 21.4072,41.4556L 26.0661,41.4556L 30.9337,56.9855L 27.1143,56.9855L 25.903,52.8055 Z M 21.9196,50.2801L 25.3905,50.2801L 24.4122,46.9804L 23.9987,45.4806L 23.6201,43.981L 23.5736,43.981L 23.2212,45.4941L 22.8514,47.0194L 21.9196,50.2801 Z"
                  Fill="Black">
                <Path.LayoutTransform>
                    <ScaleTransform ScaleX="0.36" ScaleY="0.36"/>
                </Path.LayoutTransform>
            </Path>
        </Canvas>

        <!-- Asterisk-dot: regex mode active -->
        <Canvas x:Key="regexIcon" Width="16" Height="16">
            <Path Canvas.Top="-6" Canvas.Left="-3"
                  Data="M16,16.92C15.67,16.97 15.34,17 15,17C14.66,17 14.33,16.97 14,16.92V13.41L11.5,15.89C11,15.5 10.5,15 10.11,14.5L12.59,12H9.08C9.03,11.67 9,11.34 9,11C9,10.66 9.03,10.33 9.08,10H12.59L10.11,7.5C10.3,7.25 10.5,7 10.76,6.76V6.76C11,6.5 11.25,6.3 11.5,6.11L14,8.59V5.08C14.33,5.03 14.66,5 15,5C15.34,5 15.67,5.03 16,5.08V8.59L18.5,6.11C19,6.5 19.5,7 19.89,7.5L17.41,10H20.92C20.97,10.33 21,10.66 21,11C21,11.34 20.97,11.67 20.92,12H17.41L19.89,14.5C19.7,14.75 19.5,15 19.24,15.24V15.24C19,15.5 18.75,15.7 18.5,15.89L16,13.41V16.92H16V16.92M5,19A2,2 0 0,1 7,17A2,2 0 0,1 9,19A2,2 0 0,1 7,21A2,2 0 0,1 5,19H5Z"
                  Fill="Black">
                <Path.LayoutTransform>
                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                </Path.LayoutTransform>
            </Path>
        </Canvas>
    </Page.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- search bar          -->
            <RowDefinition Height="Auto"/>  <!-- check/uncheck/toggle-->
            <RowDefinition Height="*"/>     <!-- parameter list      -->
            <RowDefinition Height="Auto"/>  <!-- category filter     -->
            <RowDefinition Height="Auto"/>  <!-- source buttons      -->
            <RowDefinition Height="Auto"/>  <!-- paste buttons       -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Search bar ───────────────────────────────────── -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <ToggleButton x:Name="regexToggle_b"
                          ToolTip="{DynamicResource TooltipToggleRegex}"
                          Content="{StaticResource filterIcon}"
                          Width="24" Height="24"
                          Margin="0,0,6,0"
                          DockPanel.Dock="Left"
                          Click="toggle_regex"/>
            <Grid>
                <TextBox x:Name="search_tb"
                         Height="24"
                         Padding="5,0,26,0"
                         VerticalContentAlignment="Center"
                         TextChanged="search_changed"/>
                <Button x:Name="clrsearch_b"
                        Visibility="Collapsed"
                        Width="22" Height="22"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,1,0"
                        BorderThickness="0"
                        Style="{StaticResource ClearButton}"
                        Click="clear_search">
                    <Canvas Width="16" Height="16">
                        <Path Canvas.Top="1" Canvas.Left="1"
                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                              Fill="DimGray">
                            <Path.LayoutTransform>
                                <ScaleTransform ScaleX="0.7" ScaleY="0.7"/>
                            </Path.LayoutTransform>
                        </Path>
                    </Canvas>
                </Button>
            </Grid>
        </DockPanel>

        <!-- ── Row 1: Check / Uncheck / Toggle ────────────────────── -->
        <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,6">
            <Button Content="{DynamicResource BtnCheckAll}"   Height="22" Click="check_all"   Margin="0,0,2,0"/>
            <Button Content="{DynamicResource BtnUncheckAll}" Height="22" Click="uncheck_all" Margin="2,0,2,0"/>
            <Button Content="{DynamicResource BtnToggleAll}"  Height="22" Click="toggle_all"  Margin="2,0,0,0"/>
        </UniformGrid>

        <!-- ── Row 2: Parameter history list ──────────────────────── -->
        <ListView x:Name="paramListView" Grid.Row="2" Margin="0,0,0,6"
                  SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <!-- checkbox column -->
                    <GridViewColumn Width="32">
                        <GridViewColumn.Header>
                            <TextBlock Text=""/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Click="checkbox_click"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <!-- parameter name -->
                    <GridViewColumn Width="130"
                                    DisplayMemberBinding="{Binding Name}">
                        <GridViewColumn.Header>
                            <TextBlock Text="{DynamicResource ColParameter}"/>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <!-- display value -->
                    <GridViewColumn Width="115"
                                    DisplayMemberBinding="{Binding DisplayValue}">
                        <GridViewColumn.Header>
                            <TextBlock Text="{DynamicResource ColValue}"/>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <!-- category: single name or "multiple" -->
                    <GridViewColumn Width="80"
                                    DisplayMemberBinding="{Binding Category}">
                        <GridViewColumn.Header>
                            <TextBlock Text="{DynamicResource ColCategory}"/>
                        </GridViewColumn.Header>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Row 3: Category selection filter toggle ─────────────── -->
        <CheckBox x:Name="categoryFilterCheck"
                  Grid.Row="3"
                  Content="{DynamicResource ChkRestrictCategories}"
                  Margin="2,0,0,6"
                  ToolTip="{DynamicResource TooltipRestrictCategories}"/>

        <!-- ── Row 4: Load-source buttons ─────────────────────────────────── -->
        <UniformGrid Grid.Row="4" Rows="1" Margin="0,0,0,4">

            <!-- tag-multiple: parameters are tagged key/value pairs on an element -->
            <Button Height="28" Margin="0,0,2,0"
                    Click="load_from_element"
                    ToolTip="{DynamicResource TooltipElemParams}">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="15" Height="15" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Data="M5.5,9A1.5,1.5 0 0,0 7,7.5A1.5,1.5 0 0,0 5.5,6A1.5,1.5 0 0,0 4,7.5A1.5,1.5 0 0,0 5.5,9M17.41,11.58C17.77,11.94 18,12.44 18,13C18,13.55 17.78,14.05 17.41,14.41L12.41,19.41C12.05,19.77 11.55,20 11,20C10.45,20 9.95,19.78 9.58,19.41L2.59,12.42C2.22,12.05 2,11.55 2,11V6C2,4.89 2.89,4 4,4H9C9.55,4 10.05,4.22 10.41,4.58L17.41,11.58M13.54,5.71L14.54,4.71L21.41,11.58C21.78,11.94 22,12.45 22,13C22,13.55 21.78,14.05 21.41,14.41L16.04,19.79L15.04,18.79L20.75,13L13.54,5.71Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource BtnElemParams}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- eye-outline: reading / inspecting the active view -->
            <Button Height="28" Margin="2,0,2,0"
                    Click="load_from_view_filters"
                    ToolTip="{DynamicResource TooltipViewFilters}">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="15" Height="15" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource BtnViewFilters}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- filter (funnel): filtering down to the most-common value -->
            <Button Height="28" Margin="2,0,0,0"
                    Click="load_from_filter_and_element"
                    ToolTip="{DynamicResource TooltipFilterElem}">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="15" Height="15" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Data="M14,12V19.88C14.04,20.18 13.94,20.5 13.71,20.71C13.32,21.1 12.69,21.1 12.3,20.71L10.29,18.7C10.06,18.47 9.96,18.16 10,17.87V12H9.97L4.21,4.62C3.87,4.19 3.95,3.56 4.38,3.22C4.57,3.08 4.78,3 5,3V3H19V3C19.22,3 19.43,3.08 19.62,3.22C20.05,3.56 20.13,4.19 19.79,4.62L14.03,12H14Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource BtnFilterElem}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </UniformGrid>

        <!-- ── Row 5: Paste buttons ────────────────────────────────────────── -->
        <UniformGrid Grid.Row="5" Rows="1">

            <!-- cursor-default: clicking one element at a time -->
            <Button x:Name="pasteSingleBtn"
                    Height="28" Margin="0,0,2,0"
                    IsEnabled="False"
                    Click="paste_single"
                    ToolTip="{DynamicResource TooltipPasteOne}">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="15" Height="15" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Data="M13.64,21.97C13.14,22.21 12.54,22 12.31,21.5L10.13,16.76L7.62,18.78C7.45,18.92 7.24,19 7,19A1,1 0 0,1 6,18V3A1,1 0 0,1 7,2C7.24,2 7.47,2.09 7.64,2.23L7.65,2.22L19.14,11.86C19.57,12.22 19.62,12.85 19.27,13.27C19.12,13.45 18.91,13.57 18.7,13.61L15.54,14.23L17.74,18.96C18,19.46 17.76,20.05 17.26,20.28L13.64,21.97Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource BtnPasteOne}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- crop-free: the four corner handles of a drag-selection rectangle -->
            <Button x:Name="pasteRectBtn"
                    Height="28" Margin="2,0,2,0"
                    IsEnabled="False"
                    Click="paste_rectangle"
                    ToolTip="{DynamicResource TooltipPasteBox}">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="15" Height="15" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Data="M3,3H9V5H5V9H3V3M21,3V9H19V5H15V3H21M3,15V21H9V19H5V15H3M19,19H15V21H21V15H19V19Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource BtnPasteBox}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- check-all: multiple items already selected, paste to all at once -->
            <Button x:Name="pasteSelBtn"
                    Height="28" Margin="2,0,0,0"
                    IsEnabled="False"
                    Click="paste_selection"
                    ToolTip="{DynamicResource TooltipPasteSel}">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="15" Height="15" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Data="M0.41,13.41L6,19L7.41,17.58L1.83,12M22.24,5.58L11.66,16.17L7.5,12L6.07,13.41L11.66,19L23.66,7M18,7L16.59,5.58L10.24,11.93L11.66,13.34L18,7Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource BtnPasteSel}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </UniformGrid>
    </Grid>
</Page>
