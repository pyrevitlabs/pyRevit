<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="Title">3D 测量工具</system:String>
    
    <system:String x:Key="CurrentMeasurement">当前测量</system:String>
    <system:String x:Key="Point1NotSelected">点 1：未选择</system:String>
    <system:String x:Key="Point2NotSelected">点 2：未选择</system:String>
    <system:String x:Key="MeasurementHistory">测量历史</system:String>
    <system:String x:Key="NoMeasurementsYet">尚无测量</system:String>
    <system:String x:Key="PressESCToExit">按 ESC 退出</system:String>
    
    <system:String x:Key="Point1Format">点 1：{}</system:String>
    <system:String x:Key="Point2Format">点 2：{}</system:String>
    <system:String x:Key="DeltaXFormat">ΔX：{:>15}</system:String>
    <system:String x:Key="DeltaYFormat">ΔY：{:>15}</system:String>
    <system:String x:Key="DeltaZFormat">ΔZ：{:>15}</system:String>
    <system:String x:Key="DiagonalFormat">对角线：{}</system:String>
    <system:String x:Key="SlopeFormat">坡度：{}</system:String>
    
    <system:String x:Key="MeasurementHistoryEntry" xml:space="preserve">
测量 {}：
    P1：{}
    P2：{}
    ΔX：{:>15}
    ΔY：{:>15}
    ΔZ：{:>15}
    对角线：{} 
    坡度：{}
    </system:String>
    
    <system:String x:Key="WarningBarPickFirstPoint">选择第一个点</system:String>
    <system:String x:Key="WarningBarPickSecondPoint">选择第二个点</system:String>
    <system:String x:Key="AlertMeasurementCancelled">由于无效操作，测量已取消。请重试。</system:String>
    <system:String x:Key="AlertMeasurementErrorTitle">测量错误</system:String>
    <system:String x:Key="AlertUnexpectedError">测量期间发生意外错误。请查看日志以获取详细信息。</system:String>
    <system:String x:Key="ToastMeasurementsCopied">测量已复制到剪贴板！</system:String>
    <system:String x:Key="ToastMeasure3DTitle">3D 测量</system:String>
    <system:String x:Key="ProjectUnitLengthUnits" xml:space="preserve">
长度单位（在项目单位中调整）：
    </system:String>
    <system:String x:Key="ProjectUnitSlopeUnits" xml:space="preserve">
坡度单位（在项目单位中调整）：
    </system:String>
</ResourceDictionary>
