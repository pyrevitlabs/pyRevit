<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="Title">3D Measure Tool</system:String>
    
    <system:String x:Key="CurrentMeasurement">Current Measurement</system:String>
    <system:String x:Key="Point1NotSelected">Point 1: Not selected</system:String>
    <system:String x:Key="Point2NotSelected">Point 2: Not selected</system:String>
    <system:String x:Key="MeasurementHistory">Measurement History</system:String>
    <system:String x:Key="NoMeasurementsYet">No measurements yet</system:String>
    <system:String x:Key="PressESCToExit">Press ESC to exit</system:String>
    
    <system:String x:Key="Point1Format">Point 1: {}</system:String>
    <system:String x:Key="Point2Format">Point 2: {}</system:String>
    <system:String x:Key="DeltaXFormat">ΔX: {:>15}</system:String>
    <system:String x:Key="DeltaYFormat">ΔY: {:>15}</system:String>
    <system:String x:Key="DeltaZFormat">ΔZ: {:>15}</system:String>
    <system:String x:Key="DiagonalFormat">Diagonal: {}</system:String>
    <system:String x:Key="SlopeFormat">Slope: {}</system:String>
    
    <system:String x:Key="MeasurementHistoryEntry" xml:space="preserve">
Measurement {}: 
    P1: {}  
    P2: {}  
    ΔX: {:>15}
    ΔY: {:>15}
    ΔZ: {:>15}
    Diagonal: {}
    Slope: {}
    </system:String>
    
    <system:String x:Key="WarningBarPickFirstPoint">Pick first point</system:String>
    <system:String x:Key="WarningBarPickSecondPoint">Pick second point</system:String>
    <system:String x:Key="AlertMeasurementCancelled">Measurement cancelled due to invalid operation. Please try again.</system:String>
    <system:String x:Key="AlertMeasurementErrorTitle">Measurement Error</system:String>
    <system:String x:Key="AlertUnexpectedError">An unexpected error occurred during measurement. Check the log for details.</system:String>
    <system:String x:Key="ToastMeasurementsCopied">Measurements copied to Clipboard!</system:String>
    <system:String x:Key="ToastMeasure3DTitle">Measure 3D</system:String>
    <system:String x:Key="ProjectUnitLengthUnits" xml:space="preserve">
Length Units (adjust in Project Units):
    </system:String>
    <system:String x:Key="ProjectUnitSlopeUnits" xml:space="preserve">
Slope Units (adjust in Project Units):
    </system:String>
</ResourceDictionary>
