<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ShowInTaskbar="False"
        Width="720" Height="750"
        MinWidth="720" MinHeight="480"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Title="Keynote Manager"
        Closing="window_closing"
        KeyDown="window_keydown">

    <Window.Resources>
        <!-- ============================================================ -->
        <!-- COLOR PALETTE                                                -->
        <!-- ============================================================ -->
        <SolidColorBrush x:Key="AccentBrush"        Color="#2B579A"/>
        <SolidColorBrush x:Key="AccentLightBrush"   Color="#D6E4F0"/>
        <SolidColorBrush x:Key="AccentHoverBrush"   Color="#3A6FB0"/>
        <SolidColorBrush x:Key="BorderBrush"        Color="#D1D1D1"/>
        <SolidColorBrush x:Key="BorderLightBrush"   Color="#E8E8E8"/>
        <SolidColorBrush x:Key="BgPanelBrush"       Color="#F5F5F5"/>
        <SolidColorBrush x:Key="BgWhiteBrush"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6E6E6E"/>
        <SolidColorBrush x:Key="TextMutedBrush"     Color="#999999"/>
        <SolidColorBrush x:Key="WarningBrush"       Color="#CA5010"/>
        <SolidColorBrush x:Key="DangerBrush"        Color="#D13438"/>
        <SolidColorBrush x:Key="LockedBgBrush"      Color="#FFF4CE"/>
        <SolidColorBrush x:Key="DragOverBrush"      Color="#E8F0FE"/>
        <SolidColorBrush x:Key="UsedBadgeBgBrush"   Color="#E8F5E9"/>
        <SolidColorBrush x:Key="UsedBadgeFgBrush"   Color="#2E7D32"/>
        <SolidColorBrush x:Key="CatBadgeBrush"      Color="#333333"/>

        <!-- ============================================================ -->
        <!-- BASE BUTTON STYLES                                           -->
        <!-- ============================================================ -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
        </Style>

        <Style x:Key="ToolbarSep" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="28,0,28,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource BgWhiteBrush}"/>
        </Style>

        <!-- ============================================================ -->
        <!-- TREEVIEW ITEM CONTAINER                                      -->
        <!-- ============================================================ -->
        <Style x:Key="TreeItemContainer" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding locked}" Value="True">
                    <Setter Property="Background" Value="{StaticResource LockedBgBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding used}" Value="True">
                    <Setter Property="FontWeight" Value="Medium"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!-- HIERARCHICAL DATA TEMPLATE (the core visual for each node)   -->
        <!-- ============================================================ -->
        <HierarchicalDataTemplate x:Key="KeynoteTreeItem"
                                  ItemsSource="{Binding children}">
            <Border x:Name="itemBorder" Padding="4,4" Margin="0,0,0,0"
                    CornerRadius="3"
                    AllowDrop="True"
                    DragOver="tree_item_drag_over"
                    DragLeave="tree_item_drag_leave"
                    Drop="tree_item_drop">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- KEY BADGE -->
                    <Border x:Name="keyBadge" Grid.Column="0"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="2" Padding="6,1,6,2"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            MinWidth="36" MaxWidth="140">
                        <TextBlock Text="{Binding key}"
                                   Foreground="White" FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <!-- KEYNOTE TEXT -->
                    <TextBlock x:Name="textDisplay" Grid.Column="1"
                               Text="{Binding text}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"/>

                    <!-- STATUS BADGES -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0,0,0">
                        <!-- Child count -->
                        <Border x:Name="childCountBadge" Visibility="Collapsed"
                                Background="{StaticResource BorderLightBrush}"
                                CornerRadius="8" Padding="5,1,5,2"
                                Margin="0,0,4,0">
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} items">
                                        <Binding Path="children.Count"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>
                        <!-- Used count -->
                        <Border x:Name="usedBadge" Visibility="Collapsed"
                                Background="{StaticResource UsedBadgeBgBrush}"
                                CornerRadius="8" Padding="5,1,5,2"
                                Margin="0,0,4,0"
                                ToolTip="{Binding tooltip}">
                            <TextBlock Foreground="{StaticResource UsedBadgeFgBrush}"
                                       FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}x">
                                        <Binding Path="used_count"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>
                        <!-- Lock badge -->
                        <Border x:Name="lockBadge" Visibility="Collapsed"
                                Background="{StaticResource WarningBrush}"
                                CornerRadius="8" Padding="6,1,6,2">
                            <TextBlock Foreground="White"
                                       FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="&#x1F512; {0}">
                                        <Binding Path="owner"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding is_category}" Value="True">
                    <Setter TargetName="keyBadge"    Property="Background" Value="{StaticResource CatBadgeBrush}"/>
                    <Setter TargetName="textDisplay"  Property="FontWeight" Value="SemiBold"/>
                    <Setter TargetName="textDisplay"  Property="FontSize"   Value="14"/>
                    <Setter TargetName="itemBorder"   Property="Margin"     Value="0,4,0,2"/>
                    <Setter TargetName="childCountBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding used}" Value="True">
                    <Setter TargetName="usedBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding locked}" Value="True">
                    <Setter TargetName="lockBadge"  Property="Visibility" Value="Visible"/>
                    <Setter TargetName="textDisplay" Property="Foreground"
                            Value="{StaticResource TextMutedBrush}"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

    </Window.Resources>

    <!-- ================================================================ -->
    <!-- MAIN LAYOUT                                                      -->
    <!-- ================================================================ -->
    <Grid Background="{StaticResource BgPanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 — FILE TOOLBAR -->
        <Border Grid.Row="0"
                Background="{StaticResource BgWhiteBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource FlatButton}"
                            Content="Import" ToolTip="Import from .txt (Ctrl+I)"
                            Click="import_keynotes"/>
                    <Button Style="{StaticResource FlatButton}"
                            Content="Export All" Click="export_keynotes"/>
                    <Button Style="{StaticResource FlatButton}"
                            Content="Export Visible" Click="export_visible_keynotes"/>
                    <Rectangle Style="{StaticResource ToolbarSep}"/>
                    <Button Style="{StaticResource FlatButton}"
                            Content="Change File" Click="change_keynote_file"/>
                    <Button Style="{StaticResource ToolbarButton}"
                            Content="&#x1F4C2;" FontSize="14"
                            ToolTip="Show in Explorer" Click="show_keynote_file"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource FlatButton}"
                            Content="&#x21BB; Refresh" ToolTip="F5" Click="refresh"/>
                    <Rectangle Style="{StaticResource ToolbarSep}"/>
                    <Button Style="{StaticResource AccentButton}"
                            Content="Update Model" Padding="14,4"
                            Click="update_model"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ROW 1 — SEARCH + TREE TOOLBAR -->
        <Border Grid.Row="1"
                Background="{StaticResource BgWhiteBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search -->
                <DockPanel Grid.Row="0">
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource FlatButton}"
                            Content="&#x25BC; Filters" Margin="6,0,0,0"
                            Click="custom_filter"/>
                    <Grid>
                        <TextBox x:Name="search_tb" Style="{StaticResource SearchBox}"
                                 TextChanged="search_txt_changed"/>
                        <TextBlock Text="&#x1F50D;  Search keynotes..."
                                   FontSize="12" IsHitTestVisible="False"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Margin="8,0,0,0"
                                   Foreground="{StaticResource TextMutedBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=search_tb}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button x:Name="clrsearch_b" Visibility="Collapsed"
                                Style="{StaticResource FlatButton}"
                                HorizontalAlignment="Right" Width="24" Height="24"
                                Content="&#x2715;" FontSize="10"
                                Foreground="{StaticResource TextMutedBrush}"
                                Click="clear_search"/>
                    </Grid>
                </DockPanel>

                <!-- Action toolbar -->
                <DockPanel Grid.Row="1" Margin="0,5,0,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,0,0,0">
                        <TextBlock Text="Place:" VerticalAlignment="Center"
                                   FontSize="11" Margin="0,0,6,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <RadioButton x:Name="userknote_rb" Content="User"
                                     VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                        <RadioButton x:Name="elementknote_rb" Content="Element"
                                     VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                        <RadioButton x:Name="materialknote_rb" Content="Material"
                                     VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <!-- Add Group / Keynote -->
                        <Button x:Name="addCategoryBtn" Style="{StaticResource ToolbarButton}"
                                ToolTip="Add group (top-level category)" Click="add_category">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="Grp" FontSize="9" Margin="2,0,0,0"
                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="addKeynoteBtn" Style="{StaticResource ToolbarButton}"
                                ToolTip="Add keynote (Ctrl+N)" Click="add_keynote">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="Key" FontSize="9" Margin="2,0,0,0"
                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>

                        <Rectangle Style="{StaticResource ToolbarSep}"/>

                        <!-- HIERARCHY: Indent / Outdent / Move Up / Move Down -->
                        <Button x:Name="indentBtn" Style="{StaticResource ToolbarButton}" Width="34"
                                ToolTip="Indent — make child of sibling above (Tab)"
                                IsEnabled="False" Click="indent_keynote">
                            <TextBlock Text="&#x21E5;" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Button>
                        <Button x:Name="outdentBtn" Style="{StaticResource ToolbarButton}" Width="34"
                                ToolTip="Outdent — promote up one level (Shift+Tab)"
                                IsEnabled="False" Click="outdent_keynote">
                            <TextBlock Text="&#x21E4;" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Button>
                        <Button x:Name="moveUpBtn" Style="{StaticResource ToolbarButton}" Width="28"
                                ToolTip="Move up (Ctrl+Up)" IsEnabled="False" Click="move_up">
                            <TextBlock Text="&#x25B2;" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                        <Button x:Name="moveDownBtn" Style="{StaticResource ToolbarButton}" Width="28"
                                ToolTip="Move down (Ctrl+Down)" IsEnabled="False" Click="move_down">
                            <TextBlock Text="&#x25BC;" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>

                        <Rectangle Style="{StaticResource ToolbarSep}"/>

                        <!-- Edit / Duplicate / Re-Key -->
                        <Button x:Name="editKeynoteBtn" Style="{StaticResource ToolbarButton}"
                                Content="&#x270E;" FontSize="13"
                                ToolTip="Edit (F2)" IsEnabled="False" Click="edit_keynote"/>
                        <Button x:Name="dupKeynoteBtn" Style="{StaticResource ToolbarButton}"
                                Content="&#x2750;" FontSize="13"
                                ToolTip="Duplicate (Ctrl+D)" IsEnabled="False" Click="duplicate_keynote"/>
                        <Button x:Name="rekeyBtn" Style="{StaticResource ToolbarButton}"
                                Content="&#x1F511;" FontSize="12"
                                ToolTip="Change key" IsEnabled="False" Click="rekey_keynote"/>

                        <Rectangle Style="{StaticResource ToolbarSep}"/>

                        <!-- Capitalization -->
                        <Button x:Name="caseBtn" Style="{StaticResource ToolbarButton}"
                                Width="36" ToolTip="Change text capitalization"
                                IsEnabled="False" Click="show_case_menu">
                            <TextBlock Text="Aa" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="caseMenu">
                                    <MenuItem Header="UPPER CASE"   Click="to_upper"    InputGestureText="TT"/>
                                    <MenuItem Header="lower case"   Click="to_lower"    InputGestureText="tt"/>
                                    <MenuItem Header="Title Case"   Click="to_title"    InputGestureText="Tt"/>
                                    <MenuItem Header="Sentence case" Click="to_sentence" InputGestureText="Se"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Rectangle Style="{StaticResource ToolbarSep}"/>

                        <!-- Delete -->
                        <Button x:Name="removeBtn" Style="{StaticResource ToolbarButton}"
                                Content="&#x2715;" FontSize="12"
                                Foreground="{StaticResource DangerBrush}"
                                ToolTip="Delete (Del)" IsEnabled="False" Click="remove_keynote"/>

                        <Rectangle Style="{StaticResource ToolbarSep}"/>

                        <!-- Find / Place -->
                        <Button x:Name="findBtn" Style="{StaticResource ToolbarButton}"
                                Content="&#x1F50D;" FontSize="12"
                                ToolTip="Find in model" IsEnabled="False" Click="show_keynote"/>
                        <Button x:Name="placeBtn" Style="{StaticResource ToolbarButton}"
                                Content="&#x1F4CC;" FontSize="12"
                                ToolTip="Place in model" IsEnabled="False" Click="place_keynote"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <!-- ROW 2 — THE TREE -->
        <Grid Grid.Row="2" Background="{StaticResource BgWhiteBrush}">
            <TextBlock x:Name="emptyStateMsg"
                       Text="No keynotes loaded. Add a group to get started."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                       Visibility="Collapsed"/>

            <TreeView x:Name="keynotes_tv"
                      BorderThickness="0" Background="Transparent" Padding="6,4"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ItemTemplate="{StaticResource KeynoteTreeItem}"
                      ItemContainerStyle="{StaticResource TreeItemContainer}"
                      SelectedItemChanged="selected_keynote_changed"
                      PreviewMouseLeftButtonDown="tree_preview_mouse_down"
                      PreviewMouseMove="tree_preview_mouse_move"
                      PreviewMouseDoubleClick="tree_double_click"
                      AllowDrop="True"
                      DragOver="tree_drag_over"
                      Drop="tree_drop"/>
        </Grid>

        <!-- ROW 3 — STATUS BAR -->
        <Border Grid.Row="3" Background="{StaticResource AccentBrush}" Padding="10,4">
            <DockPanel>
                <TextBlock x:Name="statusRight" DockPanel.Dock="Right"
                           Foreground="White" FontSize="11" Opacity="0.8"/>
                <TextBlock x:Name="statusLeft"
                           Foreground="White" FontSize="11" Opacity="0.9"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
