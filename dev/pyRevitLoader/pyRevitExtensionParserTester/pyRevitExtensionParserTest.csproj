<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<DisableImplicitProps>true</DisableImplicitProps>
	<DisableImplicitTargets>true</DisableImplicitTargets>
	<IronPythonVersion>IPY342</IronPythonVersion>
	<Version>3.4.2</Version>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
	<UseLoader>false</UseLoader>
	<UseIronPython>false</UseIronPython>
    <UseRevit>false</UseRevit>
    <UseAssemblyBuilder>true</UseAssemblyBuilder>
    <UseExtensionParser>true</UseExtensionParser>
    <LangVersion>latest</LangVersion>
    <TestTfmsInParallel>false</TestTfmsInParallel>
    <SkipPyRevitDeploy>true</SkipPyRevitDeploy>
    <RunSettingsFilePath>test.runsettings</RunSettingsFilePath>
	<!-- Suppress NUnit analyzer suggestions for classic assertion model and related style hints -->
	<NoWarn>$(NoWarn);NUnit2005;NUnit2006;NUnit1033;NUnit2048;NUnit2049</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="TestHelpers\TempFileTestBase.cs" />
    <Compile Include="TestHelpers\TestExtensionBuilder.cs" />
    <Compile Include="DarkIconTests.cs" />
    <Compile Include="TestConfiguration.cs" />
    <Compile Include="LocalizationTests.cs" />
    <Compile Include="PanelButtonAndIconTests.cs" />
    <Compile Include="PanelBackgroundTests.cs" />
    <Compile Include="IconParsingTests.cs" />
    <Compile Include="IconFunctionalityTests.cs" />
    <Compile Include="BundleTooltipFixTest.cs" />
    <Compile Include="ComponentValidationTests.cs" />
    <Compile Include="PanelButtonBundleTests.cs" />
    <Compile Include="ParsedBundleTests.cs" />
    <Compile Include="ParsedComponentTests.cs" />
    <Compile Include="ParserBasicTests.cs" />
    <Compile Include="ParserErrorHandlingTests.cs" />
    <Compile Include="DiagnosticTests.cs" />
    <Compile Include="QuotedValueTests.cs" />
    <Compile Include="QuoteDebuggingTest.cs" />
    <Compile Include="FullIntegrationQuoteTest.cs" />
    <Compile Include="StartupScriptTests.cs" />
    <Compile Include="SeparatorTests.cs" />
    <Compile Include="DebugPanelCustomTitleTest.cs" />
    <Compile Include="CSharpScriptTests.cs" />
    <Compile Include="DynamoScriptTests.cs" />
    <Compile Include="ExtensionManagerServiceTests.cs" />
    <Compile Include="AssemblyBuilderServiceTests.cs" />
    <Compile Include="HookManagerTests.cs" />
    <Compile Include="SessionManagerIntegrationTests.cs" />
    <Compile Include="PythonScriptMultiLangTest.cs" />
    <Compile Include="ComboBoxTests.cs" />
    <Compile Include="SmartButtonTests.cs" />
    <Compile Include="TemplateInheritanceTests.cs" />
    <Compile Include="ControlIdTests.cs" />
    <Compile Include="MultilineTitleTest.cs" />
    <Compile Include="UrlButtonTests.cs" />
    <Compile Include="HelpUrlTests.cs" />
    <Compile Include="ScriptMetadataParsingTest.cs" />
    <Compile Include="VersionFilteringTests.cs" />
    <Compile Include="EnvDictionarySeederTests.cs" />
    <Compile Include="PyRevitRootResolutionTests.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="8.0.1" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
    <PackageReference Include="NUnit" Version="4.5.1" />
    <PackageReference Include="NUnit.Analyzers" Version="4.12.0" />
    <PackageReference Include="NUnit3TestAdapter" Version="6.2.0" />
    <PackageReference Include="System.Drawing.Common" Version="10.0.5" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <Reference Include="pyRevitLabs.NLog">
      <HintPath>..\..\libs\netfx\pyRevitLabs.NLog.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="pyRevitLabs.Json">
      <HintPath>..\..\libs\netfx\pyRevitLabs.Json.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <Reference Include="pyRevitLabs.NLog">
      <HintPath>..\..\libs\netcore\pyRevitLabs.NLog.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="pyRevitLabs.Json">
      <HintPath>..\..\libs\netcore\pyRevitLabs.Json.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Using Include="NUnit.Framework" />
    <Using Include="NUnit.Framework.Legacy" />
  </ItemGroup>

</Project>
