<ControlTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel LastChildFill="False">

        <!-- Value badge — right side, hidden until hasvalue is True -->
        <Border x:Name="ValueBadge"
                DockPanel.Dock="Right"
                Background="#3C3C3C"
                Height="16"
                MaxWidth="120"
                Margin="6,0,4,0"
                Padding="6,0,6,0"
                Visibility="Collapsed"
                CornerRadius="4">
            <TextBlock Text="{Binding displayvalue}"
                       Foreground="#CCCCCC"
                       FontSize="10"
                       FontStyle="Italic"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Left side: name + pill badges -->
        <WrapPanel>
            <TextBlock Text="{Binding name}" Margin="10,0,0,0">
                <TextBlock.ToolTip>
                    <TextBlock>
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Parameter Group: {0}&#x0a;Shared Parameter: {1}&#x0a;Parameter Id: {2}">
                                <Binding Path="grouptype"/>
                                <Binding Path="isshared"/>
                                <Binding Path="paramid"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </TextBlock.ToolTip>
            </TextBlock>
            <Border x:Name="IsType" Background="LightGray" Height="16" Margin="10,0,0,0" Padding="8,0,8,0" Visibility="Collapsed" CornerRadius="4">
                <TextBlock Text="Type" Foreground="DimGray" FontSize="10"/>
            </Border>
            <Border x:Name="IsReadOnly" Background="{DynamicResource pyRevitAccentBrush}" Height="16" Margin="10,0,0,0" Padding="8,0,8,0" Visibility="Collapsed" CornerRadius="4">
                <TextBlock Text="Read-Only" Foreground="White" FontSize="10"/>
            </Border>
            <Border x:Name="IsUnit" Background="DarkKhaki" Height="16" Margin="10,0,0,0" Padding="8,0,8,0" Visibility="Collapsed" CornerRadius="4">
                <TextBlock Text="Unit" Foreground="White" FontSize="10"/>
            </Border>
            <Border x:Name="Storagetype" Background="PowderBlue" Height="16" Margin="10,0,0,0" Padding="8,0,8,0" Visibility="Visible" CornerRadius="4">
                <TextBlock Text="{Binding storagetype}" Foreground="LightSlateGray" FontSize="10"/>
            </Border>
        </WrapPanel>

    </DockPanel>
    <ControlTemplate.Triggers>
        <DataTrigger Binding="{Binding Path=istype}" Value="True">
            <Setter TargetName="IsType" Property="Visibility" Value="Visible"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Path=isreadonly}" Value="True">
            <Setter TargetName="IsReadOnly" Property="Visibility" Value="Visible"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Path=isunit}" Value="True">
            <Setter TargetName="IsUnit" Property="Visibility" Value="Visible"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Path=hasvalue}" Value="True">
            <Setter TargetName="ValueBadge" Property="Visibility" Value="Visible"/>
        </DataTrigger>
    </ControlTemplate.Triggers>
</ControlTemplate>